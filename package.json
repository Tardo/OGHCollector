{
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "clean": "rm -rf ./static/auto",
    "build:watch": "rollup -c -w",
    "build": "rollup -c",
    "build:prod": "export NODE_ENV='production' && rollup -c",
    "lint": "eslint --cache --color . && cargo fmt --all -- --check && cargo clippy -- -D warnings",
    "lint:fix": "eslint --fix . && cargo fmt --all && cargo clippy --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-syntax-flow": "^7.29.7",
    "@babel/preset-flow": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "autoprefixer": "^10.5.2",
    "bootstrap": "^5.3.8",
    "cssnano": "^7.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "glob": "^11.1.0",
    "globals": "^17.7.0",
    "graphology": "^0.25.4",
    "husky": "^9.1.7",
    "jquery-slim": "^3.0.0",
    "jszip": "^3.10.1",
    "mirlo": "^0.7.1",
    "obliterator": "^2.0.5",
    "postcss-scss": "^4.0.9",
    "rollup": "^4.62.2",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-lib-style": "^2.5.0",
    "sigma": "^3.0.3",
    "terser": "^5.48.0"
  },
  "dependencies": {
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "js-yaml": "^4.3.0"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "trailingComma": "all",
    "bracketSpacing": false,
    "bracketSameLine": false,
    "arrowParens": "avoid",
    "requirePragma": false,
    "proseWrap": "always",
    "htmlWhitespaceSensitivity": "css",
    "vueIndentScriptAndStyle": false,
    "endOfLine": "lf",
    "embeddedLanguageFormatting": "auto",
    "singleAttributePerLine": false
  }
}
